generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id       Int    @id @default(autoincrement())
  roleName String @unique
  users    User[]
}

model Department {
  id             Int    @id @default(autoincrement())
  departmentName String
  users          User[]
  documents      Document[]
}

model User {
  id           Int           @id @default(autoincrement())
  fullName     String
  position     String
  departmentId Int?
  roleId       Int
  department   Department?   @relation(fields: [departmentId], references: [id])
  role         Role          @relation(fields: [roleId], references: [id])
  registration Registration?
  authoredDocs Document[]    @relation("DocumentAuthor")
  assignedDocs Document[]    @relation("DocumentAssignee")
  auditLogs    AuditLog[]
  passwordResetRequests PasswordResetRequest[]
}

model Registration {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  login           String    @unique
  password        String
  passwordExpires DateTime
  
  // === НОВЫЕ ПОЛЯ ДЛЯ БЛОКИРОВКИ ===
  isBlocked       Boolean   @default(false)
  wrongAttempts   Int       @default(0)
  blockedUntil    DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentStatus {
  id         Int        @id
  statusName String
  documents  Document[]
}

model Document {
  id              Int            @id @default(autoincrement())
  title           String
  taskDescription String?
  createdAt       DateTime?      @default(now())
  userId          Int
  assignedTo      Int?
  statusId        Int
  departmentId    Int?
  
  fileName        String?
  fileUrl         String?

  // === НОВЫЕ ПОЛЯ ИЗ ВАШЕГО PHP ПРОЕКТА ===
  deadline        DateTime?
  priority        String         @default("medium") // high, medium, low
  completedAt     DateTime?

  // === ПОЛЯ РЕЗУЛЬТАТА ВЫПОЛНЕНИЯ ЗАДАЧИ ===
  resultText      String?
  resultFileUrl   String?
  resultFileName  String?

  author          User           @relation("DocumentAuthor", fields: [userId], references: [id])
  assignee        User?          @relation("DocumentAssignee", fields: [assignedTo], references: [id])
  status          DocumentStatus @relation(fields: [statusId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  details   String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PasswordResetRequest {
  id        Int      @id @default(autoincrement())
  login     String
  status    String   @default("PENDING") // PENDING, RESOLVED
  createdAt DateTime @default(now())
  
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}